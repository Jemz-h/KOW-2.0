PORT=3000
NODE_ENV=development

# Database mode
DB_CLIENT=oracle
DB_FALLBACK_SQLITE=true

# Oracle connection (11g XE default)
DB_USER=your_oracle_username
DB_PASSWORD=your_oracle_password
DB_CONNECTION_STRING=localhost:1521/XE

# SQLite fallback file used only if Oracle is unavailable
SQLITE_DB_PATH=./data/kow_offline.db

# Token signing secret (JWT/HMAC)
TOKEN_SECRET=replace_with_long_random_secret

# Optional admin seed password for SQLite bootstrap
ADMIN_SEED_PASSWORD=admin123
